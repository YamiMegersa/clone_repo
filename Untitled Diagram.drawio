        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nnode \&quot;Client Devices (Mobile/PC)\&quot; &lt;&lt;device&gt;&gt; as ClientNode {\n  node \&quot;Web Browser\&quot; &lt;&lt;execution environment&gt;&gt; as Browser {\n    artifact \&quot;Groundwork HTML/JS UI\&quot; &lt;&lt;artifact&gt;&gt; as HTML\n  }\n}\n\nnode \&quot;AWS Lightsail Instance\&quot; &lt;&lt;device&gt;&gt; as AWSNode {\n  node \&quot;Linux OS\&quot; &lt;&lt;execution environment&gt;&gt; as Linux {\n    node \&quot;Node.js Environment\&quot; &lt;&lt;execution environment&gt;&gt; as NodeEnv {\n      artifact \&quot;Express API Server\&quot; &lt;&lt;artifact&gt;&gt; as API\n    }\n    node \&quot;MySQL Database Server\&quot; &lt;&lt;execution environment&gt;&gt; as MySQLNode {\n      artifact \&quot;Groundwork Schema\&quot; &lt;&lt;artifact&gt;&gt; as Schema\n    }\n  }\n}\n\nnode \&quot;Google Authentication Server\&quot; &lt;&lt;device&gt;&gt; as GoogleNode {\n   artifact \&quot;OAuth2 Service\&quot; &lt;&lt;artifact&gt;&gt; as OAuth\n}\n\n&#39; Connections\nClientNode -- AWSNode : \&quot; HTTPS : 443\&quot;\nAPI -- MySQLNode : \&quot; TCP : 3306\&quot;\nAPI -- GoogleNode : \&quot; HTTPS (Token Verify)\&quot;\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-219">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="818" width="718" x="150" y="14260" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nhide empty description\n\n&#39; Initial Registration\n[*] --&gt; Pending : Employee signs in via Google Auth\n\n&#39; State Transitions\nPending --&gt; Active : Admin verifies and approves account\nActive --&gt; Blacklisted : Admin invalidates/revokes access\n\n&#39; Final State\nBlacklisted --&gt; [*] \n\n&#39; Explicit State Definitions for Clean Formatting\nstate \&quot;Pending Verification\&quot; as Pending\nstate \&quot;Active (Verified)\&quot; as Active\nstate \&quot;Blacklisted (Suspended)\&quot; as Blacklisted\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-222">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="460" width="329" x="10" y="15580" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nhide empty description\n\n&#39; Initial Transition\n[*] --&gt; Active : User creates report\n\n&#39; Standard Lifecycle\nActive --&gt; InProgress : Admin assigns to municipal employee\nInProgress --&gt; Resolved : Employee updates to resolved\n\n&#39; Natural Termination\nResolved --&gt; [*] \n\n&#39; Administrative Deletion Paths\nActive --&gt; [*] : Admin deletes report\nInProgress --&gt; [*] : Admin deletes report\nResolved --&gt; [*] : Admin deletes report\n\n&#39; Explicit State Definitions for Formatting\nstate \&quot;Active\&quot; as Active\nstate \&quot;In-Progress\&quot; as InProgress\nstate \&quot;Resolved\&quot; as Resolved\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-224">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="542" width="732" x="10" y="16060" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam conditionStyle inside\n\nstart\n\n:Resident clicks Google Sign-In;\n:UI requests JWT from Google OAuth;\n:POST /api/auth/google {idToken};\n\nif (Is Email the Admin Address?) then (Yes)\n  :Return 200 OK &amp; role: &#39;admin&#39;;\n  :Redirect to Admin Dashboard;\n  stop\nelse (No)\n  :findOrCreate Resident Record;\n  \n  if (Is Resident BlackListed?) then (Yes)\n    :Return 403 \&quot;Account restricted\&quot;;\n    stop\n  else (No)\n    :Return 200 OK &amp; residentId;\n    :Save residentId to localStorage;\n  endif\nendif\n\n:Redirect to Resident Dashboard (Resident.html);\n:GET /api/residents/{id}/subscriptions;\n:Render Subscribed Wards Grid;\n\nif (Resident Action?) then (Manage Subscriptions)\n  if (Action?) then (Track New Ward)\n    :Click \&quot;Track New Ward\&quot;;\n    :Select Province -&gt; Municipality -&gt; Ward;\n    :POST /api/residents/subscribe;\n  else (Remove Ward)\n    :Click \&quot;Remove Ward\&quot; on Menu;\n    :Confirm via Custom Modal;\n    :DELETE /api/residents/unsubscribe;\n  endif\n  :Update Database &amp; Reload Grid;\n\nelseif (Action?) then (View Ward Ledger)\n  :Click Specific Ward Card;\n  :Redirect to WardPage.html;\n  :Fetch &amp; Render Active Ward Reports;\n  \n  if (Interact with Report?) then (Yes)\n    :Click Report Row;\n    :Open Issue Details Modal;\n    if (Action?) then (Bump Issue)\n      :Click \&quot;Bump this Issue\&quot;;\n      :Increment bump count;\n      :Save ID to localStorage (Prevent re-bump);\n      :Disable Button State;\n    else (Close)\n      :Close Modal;\n    endif\n  else (No)\n  endif\n\nelseif (Action?) then (Submit Report)\n  :Navigate to ReportPage.html;\n  :Pin Location via Leaflet Interactive Map;\n  :Select Province -&gt; Municipality -&gt; Ward (wardSelector.js);\n  :Fill details (Type: Pothole, Streetlight, etc.);\n  :POST /api/reports;\n  :Render Success Confirmation;\n\nelse (Lodge Grievance)\n  :Navigate to Grievance Form;\n  :Identify Municipal Employee (Nullable for Anonymous);\n  :Detail Personnel Complaint;\n  :POST /api/grievances;\n  :Render Success Confirmation;\nendif\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-231">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1438" width="1652" x="10" y="18400" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam conditionStyle inside\n\nstart\n\n:Admin clicks Google Sign-In;\n:UI requests JWT from Google OAuth;\n:POST /api/auth/google {idToken};\n\nif (Is Email \&quot;2820314@students.wits.ac.za\&quot;?) then (Yes)\n  :Return 200 OK &amp; role: &#39;admin&#39;;\n  :Redirect to Admin Dashboard (Admin.html);\n  \n  &#39; Dashboard Initialization\n  :Trigger parallel data fetching;\n  split\n   :GET /api/reports (Filter: Pending);\n   :Render Unassigned Reports;\n  split again\n   :GET /api/workers/pending;\n   :Render Pending Registrations;\n  split again\n   :GET /api/workers/active;\n   :Render Active Duty Roster;\n  end split\n\n  &#39; Admin Actions\n  if (Admin Action?) then (Manage Report)\n    \n    if (Choice?) then (Assign to Worker)\n      :Prompt for EmployeeID;\n      :POST /api/reports/{id}/assign;\n    elseif (Choice?) then (Set Priority)\n      :Select Priority Level;\n      :PUT /api/reports/{id}/priority;\n    else (Delete Report)\n      :Confirm Deletion;\n      :DELETE /api/admin/delete-report/{id};\n    endif\n    \n  elseif (Action?) then (Manage Worker: Approve Pending)\n    :Click \&quot;Approve\&quot;;\n    :PUT /api/workers/validate/{employeeId};\n    \n  else (Manage Worker: Invalidate Active)\n    :Click \&quot;Invalidate\&quot;;\n    :Confirm Account Disablement;\n    :PUT /api/workers/invalidate/{employeeId};\n  endif\n  \n  :Update Database &amp; Refresh Affected UI Panels;\n\nelse (No)\n  :Route to Standard Resident Authentication Flow;\n  stop\nendif\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-232">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="957" width="1577" x="420" y="19860" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nleft to right direction\nskinparam packageStyle rectangle\n\n&#39; Primary Actors (Left Side)\nactor \&quot;Resident\&quot; as Res\nactor \&quot;Central Admin\&quot; as Admin\nactor \&quot;Municipal Employee\&quot; as Worker\n\n&#39; External Services (Right Side)\nactor \&quot;Google OAuth2\\n&lt;&lt;Service&gt;&gt;\&quot; as Google\nactor \&quot;Leaflet Maps API\\n&lt;&lt;Service&gt;&gt;\&quot; as Maps\n\n&#39; System Boundary\nrectangle \&quot;Groundwork Civic Ledger\&quot; {\n  usecase \&quot;Authenticate Session\&quot; as UC_Auth\n  usecase \&quot;Pin Geospatial Location\&quot; as UC_Pin\n  \n  usecase \&quot;Submit Infrastructure Report\&quot; as UC_Report\n  usecase \&quot;Track Ward Ledger\&quot; as UC_Track\n  usecase \&quot;Lodge Personnel Grievance\&quot; as UC_Grievance\n  \n  usecase \&quot;Review &amp; Assign Reports\&quot; as UC_Assign\n  usecase \&quot;Validate Municipal Employees\&quot; as UC_Validate\n  \n  usecase \&quot;Claim Assigned Task\&quot; as UC_Claim\n  usecase \&quot;Resolve Claimed Task\&quot; as UC_Resolve\n}\n\n&#39; Primary Actor Associations\nRes --&gt; UC_Report\nRes --&gt; UC_Track\nRes --&gt; UC_Grievance\n\nAdmin --&gt; UC_Assign\nAdmin --&gt; UC_Validate\n\nWorker --&gt; UC_Claim\nWorker --&gt; UC_Resolve\n\n&#39; Include Relationships (Dotted arrows)\nUC_Report ..&gt; UC_Auth : &lt;&lt;include&gt;&gt;\nUC_Track ..&gt; UC_Auth : &lt;&lt;include&gt;&gt;\nUC_Assign ..&gt; UC_Auth : &lt;&lt;include&gt;&gt;\nUC_Validate ..&gt; UC_Auth : &lt;&lt;include&gt;&gt;\nUC_Claim ..&gt; UC_Auth : &lt;&lt;include&gt;&gt;\nUC_Resolve ..&gt; UC_Auth : &lt;&lt;include&gt;&gt;\n\n&#39; Enforcing the Claim before Resolve rule\nUC_Resolve ..&gt; UC_Claim : &lt;&lt;include&gt;&gt;\n\nUC_Report ..&gt; UC_Pin : &lt;&lt;include&gt;&gt;\n\n&#39; External Service Associations\nUC_Auth -- Google\nUC_Pin -- Maps\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-234">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="588" width="1213" x="-20" y="20840" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam conditionStyle inside\n\nstart\n\n:Municipal Employee clicks Google Sign-In;\n:UI requests JWT from Google OAuth;\n:POST /api/auth/worker/google {idToken};\n\nif (Is Token Valid?) then (Yes)\n  :findOrCreate MunicipalWorker Record;\n  \n  if (Is Employee Blacklisted?) then (Yes)\n    :Return 403 \&quot;Account Blacklisted\&quot;;\n    stop\n  else (No)\n    \n    if (Is Employee Validated by Admin?) then (Yes)\n      :Return 200 OK &amp; employeeId;\n      :Redirect to Employee Dashboard;\n      :GET /api/reports/assigned/{employeeId};\n      \n      if (Has Assigned Tasks?) then (Yes)\n        :Employee views task ledger;\n        \n        if (Task Status?) then (Assigned / Unclaimed)\n          :Click \&quot;Claim Task\&quot;;\n          :PUT /api/reports/{id}/claim;\n          :Update Status to &#39;In Progress&#39;;\n          :Update Database &amp; Reload UI;\n        else (Claimed / In Progress)\n          :Click \&quot;Mark as Complete\&quot;;\n          :PUT /api/reports/{id}/status (Status=&#39;Resolved&#39;);\n          :Update Database &amp; Reload UI;\n        endif\n        \n      else (No)\n        :Display \&quot;No active tasks assigned\&quot;;\n      endif\n      \n    else (No)\n      :Return 403 \&quot;Wait for Admin Approval\&quot;;\n      stop\n    endif\n    \n  endif\n\nelse (No)\n  :Return 401 \&quot;Invalid Security Token\&quot;;\n  stop\nendif\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-235">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="962" width="1532" x="-20" y="21450" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam componentStyle uml2\n\npackage \&quot;Groundwork Web Subsystem (Frontend)\&quot; {\n  [Static Frontend UI] &lt;&lt;component&gt;&gt; as UI\n  [Leaflet.js Map Module] &lt;&lt;component&gt;&gt; as LeafletMap\n}\n\npackage \&quot;Groundwork API Subsystem (Backend)\&quot; {\n  [server.js (Express Middleware)] &lt;&lt;component&gt;&gt; as Server\n  \n  [Worker Router] &lt;&lt;component&gt;&gt; as WorkerRoute\n  [Resident Router] &lt;&lt;component&gt;&gt; as ResidentRoute\n  [Report Router] &lt;&lt;component&gt;&gt; as ReportRoute\n  [Geography Router] &lt;&lt;component&gt;&gt; as GeoRoute\n}\n\npackage \&quot;Data Models Subsystem\&quot; {\n  [Sequelize Index] &lt;&lt;component&gt;&gt; as SeqIndex\n}\n\n&#39; External Services\n[Google OAuth2] &lt;&lt;component&gt;&gt; as GoogleAuth\n[OpenStreetMap Tile Server] &lt;&lt;component&gt;&gt; as OSM\ndatabase \&quot;MySQL\&quot; &lt;&lt;database&gt;&gt; as DB\n\n&#39; Frontend Interfaces (Ball and Socket)\nUI -(0- Server : \&quot; HTTP Requests\&quot;\nUI -(0- LeafletMap : \&quot; Initialize Coordinates\&quot;\nLeafletMap -(0- OSM : \&quot; Fetch Map Tiles (.png)\&quot;\n\n&#39; Backend to External Auth\nServer -0)- GoogleAuth : \&quot; JWT Validation\&quot;\n\n&#39; API Routing (Ball and Socket)\nServer -(0- WorkerRoute : \&quot; /api/workers\&quot;\nServer -(0- ResidentRoute : \&quot; /api/residents\&quot;\nServer -(0- ReportRoute : \&quot; /api/reports\&quot;\nServer -(0- GeoRoute : \&quot; /api/geography\&quot;\n\n&#39; ORM Connections (Ball and Socket)\nWorkerRoute -(0- SeqIndex : \&quot; ORM Queries\&quot;\nResidentRoute -(0- SeqIndex : \&quot; ORM Queries\&quot;\nReportRoute -(0- SeqIndex : \&quot; ORM Queries\&quot;\nGeoRoute -(0- SeqIndex : \&quot; ORM Queries\&quot;\n\n&#39; Database Connection (Ball and Socket)\nSeqIndex -(0- DB : \&quot; TCP Connection\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-237">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="754" width="1149" x="-20" y="22460" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="f1CdBVBtIYrvmNaZUmw5-240" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="1" vertex="1">
          <mxGeometry height="30" width="60" x="130" y="12190" as="geometry" />
        </mxCell>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam componentStyle uml2\n\npackage \&quot;Groundwork Web Subsystem (Frontend)\&quot; {\n  [Static Frontend UI] &lt;&lt;component&gt;&gt; as UI\n  [Leaflet.js Map Module] &lt;&lt;component&gt;&gt; as LeafletMap\n}\n\npackage \&quot;Groundwork API Subsystem (Backend)\&quot; {\n  [server.js (Express Middleware)] &lt;&lt;component&gt;&gt; as Server\n  \n  [Worker Router] &lt;&lt;component&gt;&gt; as WorkerRoute\n  [Resident Router] &lt;&lt;component&gt;&gt; as ResidentRoute\n  [Report Router] &lt;&lt;component&gt;&gt; as ReportRoute\n  [Geography Router] &lt;&lt;component&gt;&gt; as GeoRoute\n}\n\npackage \&quot;Data Models Subsystem\&quot; {\n  [Sequelize Index] &lt;&lt;component&gt;&gt; as SeqIndex\n}\n\n&#39; External Services\n[Google OAuth2] &lt;&lt;component&gt;&gt; as GoogleAuth\n[OpenStreetMap Tile Server] &lt;&lt;component&gt;&gt; as OSM\n&#39; CHANGED: Database is now a component/rectangle\n[MySQL] &lt;&lt;component&gt;&gt; &lt;&lt;database&gt;&gt; as DB\n\n&#39; Frontend Interfaces\nUI -(0- Server : \&quot; HTTP Requests\&quot;\nUI -(0- LeafletMap : \&quot; Initialize Coordinates\&quot;\nLeafletMap -(0- OSM : \&quot; Fetch Map Tiles (.png)\&quot;\n\n&#39; Backend to External Auth\nServer -0)- GoogleAuth : \&quot; JWT Validation\&quot;\n\n&#39; API Routing\nServer -(0- WorkerRoute : \&quot; /api/workers\&quot;\nServer -(0- ResidentRoute : \&quot; /api/residents\&quot;\nServer -(0- ReportRoute : \&quot; /api/reports\&quot;\nServer -(0- GeoRoute : \&quot; /api/geography\&quot;\n\n&#39; ORM Connections\nWorkerRoute -(0- SeqIndex : \&quot; ORM Queries\&quot;\nResidentRoute -(0- SeqIndex : \&quot; ORM Queries\&quot;\nReportRoute -(0- SeqIndex : \&quot; ORM Queries\&quot;\nGeoRoute -(0- SeqIndex : \&quot; ORM Queries\&quot;\n\n&#39; Database Connection\nSeqIndex -(0- DB : \&quot; TCP Connection\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-241">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="759" width="1149" x="-20" y="23230" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam componentStyle uml2\nleft to right direction\n\n&#39; --- EXTERNAL SERVICES ---\ncomponent \&quot;Google OAuth2\&quot; &lt;&lt;component&gt;&gt; as GoogleAuth\ncomponent \&quot;OpenStreetMap\&quot; &lt;&lt;component&gt;&gt; as OSM\n\n&#39; --- FRONTEND SUBSYSTEM ---\ncomponent \&quot;Web Frontend\&quot; &lt;&lt;subsystem&gt;&gt; &lt;&lt;component&gt;&gt; {\n  port \&quot;Submit\&quot; as pSubmit\n  port \&quot;WardView\&quot; as pWard\n  port \&quot;Auth\&quot; as pAuth\n  \n  component \&quot;:UI_Controller\&quot; as UI\n  component \&quot;:Leaflet_Map\&quot; as Map\n  component \&quot;:Ward_Selector\&quot; as Selector\n  \n  &#39; Delegation from Ports to Internal Components\n  pSubmit -- UI\n  pWard -- Selector\n  pAuth -- UI\n  \n  &#39; Internal Assembly\n  UI -(0- Selector : \&quot; Get WardID\&quot;\n  UI -(0- Map : \&quot; Get Coordinates\&quot;\n}\n\n&#39; --- API SUBSYSTEM ---\ncomponent \&quot;API Backend\&quot; &lt;&lt;subsystem&gt;&gt; &lt;&lt;component&gt;&gt; {\n  port \&quot;Gateway\&quot; as pAPI\n  port \&quot;Sec\&quot; as pSec\n  \n  component \&quot;Express_Middleware\&quot; as Server\n  component \&quot;:Report_Router\&quot; as RepRoute\n  component \&quot;:Worker_Router\&quot; as WorkRoute\n  component \&quot;:Resident_Router\&quot; as ResRoute\n  \n  &#39; Delegation\n  pAPI -- Server\n  pSec -- Server\n  \n  &#39; Internal Routing\n  Server -- RepRoute\n  Server -- WorkRoute\n  Server -- ResRoute\n}\n\n&#39; --- PERSISTENCE SUBSYSTEM ---\ncomponent \&quot;Data_Persistence\&quot; &lt;&lt;subsystem&gt;&gt; &lt;&lt;component&gt;&gt; {\n  port \&quot;Queries\&quot; as pQuery\n  \n  component \&quot;:Sequelize_ORM\&quot; as Seq\n  component \&quot;:MySQL_Instance\&quot; &lt;&lt;database&gt;&gt; as DB\n  \n  &#39; Delegation\n  pQuery -- Seq\n  \n  &#39; Internal connection\n  Seq -(0- DB : \&quot; TCP Connection\&quot;\n}\n\n&#39; --- SYSTEM-WIDE CONNECTIONS (Ball and Socket) ---\n\n&#39; Frontend to API\nUI -(0- pAPI : \&quot; HTTP Requests\&quot;\n\n&#39; API to Data\nRepRoute -(0- pQuery : \&quot; CRUD\&quot;\nWorkRoute -(0- pQuery : \&quot; CRUD\&quot;\nResRoute -(0- pQuery : \&quot; CRUD\&quot;\n\n&#39; API to External Auth\npSec -0)- GoogleAuth : \&quot; JWT Validation\&quot;\n\n&#39; Frontend to External Map Tiles\nMap -0)- OSM : \&quot; Fetch Tiles\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-242">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="610" width="2052.02" x="-20" y="24010" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n&#39; Forces a cleaner, orthogonal layout to fix spacing\nskinparam componentStyle uml2\nskinparam linetype ortho\nleft to right direction\n\n&#39; --- EXTERNAL SERVICES ---\ncomponent \&quot;Google OAuth2\&quot; &lt;&lt;component&gt;&gt; as GoogleAuth\ncomponent \&quot;OpenStreetMap\&quot; &lt;&lt;component&gt;&gt; as OSM\n\n&#39; --- FRONTEND SUBSYSTEM ---\ncomponent \&quot;Web Frontend Subsystem\&quot; &lt;&lt;subsystem&gt;&gt; &lt;&lt;component&gt;&gt; {\n  port \&quot;Auth\&quot; as pAuth\n  port \&quot;Submit\&quot; as pSubmit\n  port \&quot;WardView\&quot; as pWard\n  \n  component \&quot;:UI_Controller\&quot; as UI\n  component \&quot;:Leaflet_Map\&quot; as Map\n  component \&quot;:Ward_Selector\&quot; as Selector\n  \n  &#39; Internal Connections\n  pAuth -- UI\n  pSubmit -- UI\n  pWard -- Selector\n  \n  UI -(0- Selector\n  UI -(0- Map\n}\n\n&#39; --- API SUBSYSTEM (Includes Data Models) ---\ncomponent \&quot;Groundwork API Subsystem\&quot; &lt;&lt;subsystem&gt;&gt; &lt;&lt;component&gt;&gt; {\n  port \&quot;Gateway\&quot; as pAPI\n  port \&quot;Sec\&quot; as pSec\n  \n  component \&quot;Express_Middleware\&quot; as Server\n  \n  &#39; Nested Routing Logic\n  package \&quot;Routers\&quot; {\n    component \&quot;:Report_Router\&quot; as RepRoute\n    component \&quot;:Worker_Router\&quot; as WorkRoute\n    component \&quot;:Resident_Router\&quot; as ResRoute\n  }\n  \n  &#39; Nested Data Models (Matching your folder structure)\n  package \&quot;Data_Models_Folder\&quot; {\n    component \&quot;:Sequelize_ORM\&quot; as Seq\n    component \&quot;:MySQL_Instance\&quot; &lt;&lt;database&gt;&gt; as DB\n  }\n  \n  &#39; Internal Delegation\n  pAPI -- Server\n  pSec -- Server\n  \n  Server -- RepRoute\n  Server -- WorkRoute\n  Server -- ResRoute\n  \n  &#39; ORM Connections\n  RepRoute -(0- Seq\n  WorkRoute -(0- Seq\n  ResRoute -(0- Seq\n  Seq -(0- DB\n}\n\n&#39; --- CROSS-SUBSYSTEM CONNECTIONS ---\n\n&#39; Frontend hitting the API Gateway\nUI -(0- pAPI : \&quot;  HTTP Requests\&quot;\n\n&#39; API checking with Google\npSec -0)- GoogleAuth : \&quot;  JWT Validation\&quot;\n\n&#39; Map fetching tiles\nMap -0)- OSM : \&quot;  Fetch Tiles\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-243">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="513" width="1393" x="-20" y="24640" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam componentStyle uml2\nskinparam linetype ortho\nleft to right direction\n\n&#39; --- EXTERNAL SERVICES ---\ncomponent \&quot;Google OAuth2\&quot; &lt;&lt;component&gt;&gt; as GoogleAuth\ncomponent \&quot;OpenStreetMap\&quot; &lt;&lt;component&gt;&gt; as OSM\n\n&#39; --- FRONTEND SUBSYSTEM ---\ncomponent \&quot;Web Frontend Subsystem\&quot; &lt;&lt;subsystem&gt;&gt; &lt;&lt;component&gt;&gt; {\n  port \&quot;UI_Port\&quot; as pUI\n  \n  component \&quot;:Web_Client_Controller\&quot; as UI\n  component \&quot;:Leaflet_Map_Module\&quot; as Map\n  component \&quot;:Ward_Selector_Script\&quot; as Selector\n  \n  UI -(0- Selector\n  UI -(0- Map\n}\n\n&#39; --- API SUBSYSTEM (The Master Folder) ---\ncomponent \&quot;Groundwork API Subsystem\&quot; &lt;&lt;subsystem&gt;&gt; &lt;&lt;component&gt;&gt; {\n  port \&quot;Gateway\&quot; as pAPI\n  port \&quot;Sec\&quot; as pSec\n  \n  component \&quot;server.js (Express)\&quot; as Server\n  \n  &#39; Nested Logical Groups (Folders)\n  package \&quot;Routes\&quot; {\n    component \&quot;:Report_Router\&quot; as RepRoute\n    component \&quot;:Worker_Router\&quot; as WorkRoute\n    component \&quot;:Resident_Router\&quot; as ResRoute\n  }\n  \n  package \&quot;Models\&quot; {\n    component \&quot;:Sequelize_ORM\&quot; as Seq\n    component \&quot;:MySQL_Instance\&quot; &lt;&lt;database&gt;&gt; as DB\n  }\n  \n  &#39; Internal Wiring\n  pAPI -- Server\n  pSec -- Server\n  \n  Server -- RepRoute\n  Server -- WorkRoute\n  Server -- ResRoute\n  \n  RepRoute -(0- Seq\n  WorkRoute -(0- Seq\n  ResRoute -(0- Seq\n  Seq -(0- DB\n}\n\n&#39; --- SYSTEM-WIDE CONNECTIONS ---\nUI -(0- pAPI : \&quot; HTTP/REST\&quot;\npSec -0)- GoogleAuth : \&quot; OAuth 2.0\&quot;\nMap -0)- OSM : \&quot; Map Tiles\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-244">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="486" width="1463" x="110" y="25170" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n&#39; --- ADVANCED LAYOUT &amp; SPACING ---\nskinparam componentStyle uml2\nskinparam linetype ortho\nskinparam nodesep 80\nskinparam ranksep 120\nskinparam padding 10\nskinparam DefaultTextAlignment center\n\nleft to right direction\n\n&#39; --- EXTERNAL SERVICES ---\ncomponent \&quot;Google OAuth2\&quot; &lt;&lt;component&gt;&gt; as GoogleAuth\ncomponent \&quot;OpenStreetMap\&quot; &lt;&lt;component&gt;&gt; as OSM\n\n&#39; --- FRONTEND SUBSYSTEM ---\ncomponent \&quot;Web Frontend Subsystem\&quot; &lt;&lt;subsystem&gt;&gt; &lt;&lt;component&gt;&gt; {\n  port \&quot;UI_Port\&quot; as pUI\n  \n  component \&quot;:Web_Client_Controller\&quot; as UI\n  component \&quot;:Leaflet_Map_Module\&quot; as Map\n  component \&quot;:Ward_Selector_Script\&quot; as Selector\n  \n  &#39; Lengthened arrows to force internal spacing\n  UI -(0-- Selector\n  UI -(0-- Map\n}\n\n&#39; --- API SUBSYSTEM (The Master Folder) ---\ncomponent \&quot;Groundwork API Subsystem\&quot; &lt;&lt;subsystem&gt;&gt; &lt;&lt;component&gt;&gt; {\n  port \&quot;Gateway\&quot; as pAPI\n  port \&quot;Sec\&quot; as pSec\n  \n  component \&quot;server.js (Express)\&quot; as Server\n  \n  &#39; Nested Logical Groups (Folders)\n  package \&quot;Routes\&quot; {\n    component \&quot;:Report_Router\&quot; as RepRoute\n    component \&quot;:Worker_Router\&quot; as WorkRoute\n    component \&quot;:Resident_Router\&quot; as ResRoute\n  }\n  \n  package \&quot;Models\&quot; {\n    component \&quot;:Sequelize_ORM\&quot; as Seq\n    component \&quot;:MySQL_Instance\&quot; &lt;&lt;database&gt;&gt; as DB\n  }\n  \n  &#39; Internal Wiring with lengthened arrows\n  pAPI ---&gt; Server\n  pSec ---&gt; Server\n  \n  Server ---&gt; RepRoute\n  Server ---&gt; WorkRoute\n  Server ---&gt; ResRoute\n  \n  RepRoute -(0-- Seq\n  WorkRoute -(0-- Seq\n  ResRoute -(0-- Seq\n  Seq -(0-- DB\n}\n\n&#39; --- SYSTEM-WIDE CONNECTIONS ---\n&#39; Using triple dashes for maximum external spacing\nUI -(0--- pAPI : \&quot;   HTTP / REST   \&quot;\npSec -0)- GoogleAuth : \&quot;   OAuth 2.0   \&quot;\nMap -0)- OSM : \&quot;   Map Tiles (.png)   \&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-245">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="710" width="2967" x="550" y="25680" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam maxMessageSize 150\nautonumber\n\nactor \&quot;Resident\&quot; as Res\nparticipant \&quot;Resident Dashboard (Browser)\&quot; as UI\nparticipant \&quot;Express Server (Node.js)\&quot; as API\ndatabase \&quot;MySQL Server\&quot; as DB\n\nRes -&gt; UI : Click \&quot;Track New Ward\&quot;\n\n&#39; --- PROVINCE FETCH ---\nUI -&gt; API : GET /api/geography/provinces\nAPI -&gt; DB : SELECT * FROM Provinces\nDB --&gt; API : Result Set\nAPI --&gt; UI : JSON (Provinces Array)\n\nRes -&gt; UI : Select Province\n\n&#39; --- MUNICIPALITY FETCH ---\nUI -&gt; API : GET /api/geography/provinces/{id}/municipalities\nAPI -&gt; DB : SELECT * FROM Municipalities WHERE ProvinceID={id}\nDB --&gt; API : Result Set\nAPI --&gt; UI : JSON (Municipalities Array)\n\nRes -&gt; UI : Select Municipality\n\n&#39; --- WARD FETCH ---\nUI -&gt; API : GET /api/geography/municipalities/{id}/wards\nAPI -&gt; DB : SELECT * FROM Wards WHERE MunicipalityID={id}\nDB --&gt; API : Result Set\nAPI --&gt; UI : JSON (Wards Array)\n\nRes -&gt; UI : Click \&quot;Track Ward\&quot;\n\n&#39; --- SUBSCRIBE POST ---\nUI -&gt; API : POST /api/residents/subscribe (ResidentID, WardID)\nAPI -&gt; DB : INSERT INTO Subscriptions (ResidentID, WardID)\nDB --&gt; API : Transaction Success\nAPI --&gt; UI : 201 Created\n\n&#39; --- REFRESH GRID ---\nUI -&gt; API : GET /api/residents/{id}/subscriptions\nAPI -&gt; DB : SELECT * FROM Wards JOIN Subscriptions WHERE ResidentID={id}\nDB --&gt; API : Result Set\nAPI --&gt; UI : JSON (Updated Subscribed Wards)\n\nUI --&gt; Res : Render New Ward Card in Grid\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-246">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1113" width="777" x="1840" y="26410" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n&#39; --- ADVANCED LAYOUT &amp; SPACING ---\nskinparam ParticipantPadding 60\nskinparam SequenceMessageAlign center\nautonumber\n\nactor \&quot;Resident\&quot; as Res\nparticipant \&quot;Resident Dashboard\\n(Browser)\&quot; as UI\nparticipant \&quot;Express Server\\n(Node.js)\&quot; as API\ndatabase \&quot;MySQL Server\&quot; as DB\n\nRes -&gt; UI : Click \&quot;Track New Ward\&quot;\n\n&#39; --- PROVINCE FETCH ---\nUI -&gt; API : GET /api/geography/provinces\nAPI -&gt; DB : SELECT * FROM Provinces\nDB --&gt; API : Result Set\nAPI --&gt; UI : JSON (Provinces Array)\n\nRes -&gt; UI : Select Province\n\n&#39; --- MUNICIPALITY FETCH ---\nUI -&gt; API : GET /api/geography/provinces/{id}/municipalities\nAPI -&gt; DB : SELECT * FROM Municipalities\\nWHERE ProvinceID={id}\nDB --&gt; API : Result Set\nAPI --&gt; UI : JSON (Municipalities Array)\n\nRes -&gt; UI : Select Municipality\n\n&#39; --- WARD FETCH ---\nUI -&gt; API : GET /api/geography/municipalities/{id}/wards\nAPI -&gt; DB : SELECT * FROM Wards\\nWHERE MunicipalityID={id}\nDB --&gt; API : Result Set\nAPI --&gt; UI : JSON (Wards Array)\n\nRes -&gt; UI : Click \&quot;Track Ward\&quot;\n\n&#39; --- SUBSCRIBE POST ---\nUI -&gt; API : POST /api/residents/subscribe\\n(ResidentID, WardID)\nAPI -&gt; DB : INSERT INTO Subscriptions\\n(ResidentID, WardID)\nDB --&gt; API : Transaction Success\nAPI --&gt; UI : 201 Created\n\n&#39; --- REFRESH GRID ---\nUI -&gt; API : GET /api/residents/{id}/subscriptions\nAPI -&gt; DB : SELECT * FROM Wards\\nJOIN Subscriptions WHERE ResidentID={id}\nDB --&gt; API : Result Set\nAPI --&gt; UI : JSON (Updated Subscribed Wards)\n\nUI --&gt; Res : Render New Ward Card in Grid\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-247">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="946" width="952" x="1880" y="27540" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n&#39; --- ADVANCED LAYOUT &amp; SPACING ---\nskinparam ParticipantPadding 40\nskinparam SequenceMessageAlign center\nautonumber\n\nactor \&quot;User (Resident/Admin)\&quot; as User\nparticipant \&quot;Groundwork UI\\n(Browser)\&quot; as UI\nparticipant \&quot;Google OAuth2\\n&lt;&lt;Service&gt;&gt;\&quot; as Google\nparticipant \&quot;Express Server\\n(Node.js)\&quot; as API\ndatabase \&quot;MySQL Server\&quot; as DB\n\n&#39; --- AUTHENTICATION INITIATION ---\nUser -&gt; UI : Click \&quot;Sign In with Google\&quot;\nUI -&gt; Google : Request Authentication\nGoogle --&gt; User : Prompt Google Login Modal\nUser -&gt; Google : Enter Credentials &amp; Consent\nGoogle --&gt; UI : Return JWT (idToken)\n\n&#39; --- BACKEND VALIDATION ---\nUI -&gt; API : POST /api/auth/google\\n{ idToken }\nAPI -&gt; Google : Verify JWT Signature &amp; Audience\nGoogle --&gt; API : Token Valid (Returns Payload)\n\n&#39; --- ROUTING &amp; AUTHORIZATION LOGIC ---\nalt is Admin Email (2820314@students.wits.ac.za)\n    \n    API --&gt; UI : 200 OK (Role: Admin)\n    UI --&gt; User : Redirect to Admin Dashboard\n    \nelse is Standard Resident\n    \n    API -&gt; DB : findOrCreate Resident\\nWHERE Email = payload.email\n    DB --&gt; API : Resident Record Object\n    \n    &#39; Nested alt block for Blacklist check\n    alt is Resident Blacklisted? == True\n        \n        API --&gt; UI : 403 Forbidden (Account Restricted)\n        UI --&gt; User : Display \&quot;Account Suspended\&quot; Error\n        \n    else is Resident Blacklisted? == False\n        \n        API -&gt; API : Generate Internal Session/JWT\n        API --&gt; UI : 200 OK (Role: Resident, residentId)\n        UI --&gt; User : Redirect to Resident Dashboard\n        \n    end\n\nend\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-248">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="782" width="1074" x="230" y="28510" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n&#39; --- ADVANCED LAYOUT &amp; SPACING ---\nskinparam ParticipantPadding 40\nskinparam SequenceMessageAlign center\nautonumber\n\nactor \&quot;Resident\&quot; as Res\nparticipant \&quot;Resident Dashboard\\n(Browser)\&quot; as UI\nparticipant \&quot;Google OAuth2\\n&lt;&lt;Service&gt;&gt;\&quot; as Google\nparticipant \&quot;Express Server\\n(Node.js)\&quot; as API\ndatabase \&quot;MySQL Server\&quot; as DB\n\n&#39; --- AUTHENTICATION INITIATION ---\nRes -&gt; UI : Click \&quot;Sign In with Google\&quot;\nUI -&gt; Google : Request Authentication\nGoogle --&gt; Res : Prompt Google Login Modal\nRes -&gt; Google : Enter Credentials &amp; Consent\nGoogle --&gt; UI : Return JWT (idToken)\n\n&#39; --- BACKEND VALIDATION ---\nUI -&gt; API : POST /api/auth/google\\n{ idToken }\nAPI -&gt; Google : Verify JWT Signature &amp; Audience\nGoogle --&gt; API : Token Valid (Returns Payload)\n\n&#39; --- RESIDENT DATABASE LOOKUP ---\nAPI -&gt; DB : findOrCreate Resident\\nWHERE Email = payload.email\nDB --&gt; API : Resident Record Object\n\n&#39; --- BLACKLIST LOGIC ---\nalt is Resident Blacklisted? == True\n    \n    API --&gt; UI : 403 Forbidden (Account Restricted)\n    UI --&gt; Res : Display \&quot;Account Suspended\&quot; Error\n    \nelse is Resident Blacklisted? == False\n    \n    API -&gt; API : Generate Internal Session/JWT\n    API --&gt; UI : 200 OK (Role: Resident, residentId)\n    UI --&gt; Res : Redirect to Resident Dashboard\n    \nend\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-249">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="682" width="1020" x="20" y="29310" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\n&#39; --- ADVANCED LAYOUT &amp; SPACING ---\nskinparam ParticipantPadding 40\nskinparam SequenceMessageAlign center\nautonumber\n\nactor \&quot;Resident\&quot; as Res\nparticipant \&quot;ReportPage.html\\n(Browser)\&quot; as UI\nparticipant \&quot;OpenStreetMap\\n&lt;&lt;Service&gt;&gt;\&quot; as OSM\nparticipant \&quot;Express Server\\n(Node.js)\&quot; as API\ndatabase \&quot;MySQL Server\&quot; as DB\n\n&#39; --- PAGE INITIALIZATION &amp; MAP ---\nRes -&gt; UI : Navigate to \&quot;Report Pothole\&quot; Page\nUI -&gt; OSM : Request Map Tiles (Leaflet.js)\nOSM --&gt; UI : Return .png Map Tiles\nUI -&gt; UI : Prompt Geolocation &amp; Pin Location\n\n&#39; --- GEOGRAPHY SELECTION (wardSelector.js) ---\n&#39; Fetching from your own backend now, not GitHub\nUI -&gt; API : GET /assets/wards.csv (Static File)\nAPI --&gt; UI : Return CSV File\nUI -&gt; UI : Parse CSV &amp; Populate Province Dropdown\n\nRes -&gt; UI : Select Province\nUI -&gt; UI : Filter CSV &amp; Populate Municipalities\nRes -&gt; UI : Select Municipality\nUI -&gt; UI : Filter CSV &amp; Populate Wards\nRes -&gt; UI : Select Ward\n\n&#39; --- DATA ENTRY &amp; SUBMISSION ---\nRes -&gt; UI : Select Hazard Type &amp; Recurrence\nRes -&gt; UI : Type Situation Briefing\nRes -&gt; UI : Click \&quot;Submit Report\&quot;\n\n&#39; --- BACKEND PERSISTENCE ---\nUI -&gt; API : POST /api/reports\\n{WardID, Type, Frequency, Description, Coordinates}\nAPI -&gt; DB : INSERT INTO Reports\\n(ResidentID, WardID, Type, Progress=&#39;Active&#39;)\nDB --&gt; API : Transaction Success\nAPI --&gt; UI : 201 Created\n\nUI --&gt; Res : Render Success Confirmation UI\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-251">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="817" width="1134" x="-20" y="30010" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
