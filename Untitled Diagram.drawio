        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nnode \&quot;Client Devices (Mobile/PC)\&quot; &lt;&lt;device&gt;&gt; as ClientNode {\n  node \&quot;Web Browser\&quot; &lt;&lt;execution environment&gt;&gt; as Browser {\n    artifact \&quot;Groundwork HTML/JS UI\&quot; &lt;&lt;artifact&gt;&gt; as HTML\n  }\n}\n\nnode \&quot;AWS Lightsail Instance\&quot; &lt;&lt;device&gt;&gt; as AWSNode {\n  node \&quot;Linux OS\&quot; &lt;&lt;execution environment&gt;&gt; as Linux {\n    node \&quot;Node.js Environment\&quot; &lt;&lt;execution environment&gt;&gt; as NodeEnv {\n      artifact \&quot;Express API Server\&quot; &lt;&lt;artifact&gt;&gt; as API\n    }\n    node \&quot;MySQL Database Server\&quot; &lt;&lt;execution environment&gt;&gt; as MySQLNode {\n      artifact \&quot;Groundwork Schema\&quot; &lt;&lt;artifact&gt;&gt; as Schema\n    }\n  }\n}\n\nnode \&quot;Google Authentication Server\&quot; &lt;&lt;device&gt;&gt; as GoogleNode {\n   artifact \&quot;OAuth2 Service\&quot; &lt;&lt;artifact&gt;&gt; as OAuth\n}\n\n&#39; Connections\nClientNode -- AWSNode : \&quot; HTTPS : 443\&quot;\nAPI -- MySQLNode : \&quot; TCP : 3306\&quot;\nAPI -- GoogleNode : \&quot; HTTPS (Token Verify)\&quot;\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-219">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="818" width="718" x="150" y="14260" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nhide empty description\n\n&#39; Initial Registration\n[*] --&gt; Pending : Employee signs in via Google Auth\n\n&#39; State Transitions\nPending --&gt; Active : Admin verifies and approves account\nActive --&gt; Blacklisted : Admin invalidates/revokes access\n\n&#39; Final State\nBlacklisted --&gt; [*] \n\n&#39; Explicit State Definitions for Clean Formatting\nstate \&quot;Pending Verification\&quot; as Pending\nstate \&quot;Active (Verified)\&quot; as Active\nstate \&quot;Blacklisted (Suspended)\&quot; as Blacklisted\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-222">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="460" width="329" x="10" y="15580" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nhide empty description\n\n&#39; Initial Transition\n[*] --&gt; Active : User creates report\n\n&#39; Standard Lifecycle\nActive --&gt; InProgress : Admin assigns to municipal employee\nInProgress --&gt; Resolved : Employee updates to resolved\n\n&#39; Natural Termination\nResolved --&gt; [*] \n\n&#39; Administrative Deletion Paths\nActive --&gt; [*] : Admin deletes report\nInProgress --&gt; [*] : Admin deletes report\nResolved --&gt; [*] : Admin deletes report\n\n&#39; Explicit State Definitions for Formatting\nstate \&quot;Active\&quot; as Active\nstate \&quot;In-Progress\&quot; as InProgress\nstate \&quot;Resolved\&quot; as Resolved\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-224">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="542" width="732" x="10" y="16060" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam conditionStyle inside\n\nstart\n\n:Resident clicks Google Sign-In;\n:UI requests JWT from Google OAuth;\n:POST /api/auth/google {idToken};\n\nif (Is Email the Admin Address?) then (Yes)\n  :Return 200 OK &amp; role: &#39;admin&#39;;\n  :Redirect to Admin Dashboard;\n  stop\nelse (No)\n  :findOrCreate Resident Record;\n  \n  if (Is Resident BlackListed?) then (Yes)\n    :Return 403 \&quot;Account restricted\&quot;;\n    stop\n  else (No)\n    :Return 200 OK &amp; residentId;\n    :Save residentId to localStorage;\n  endif\nendif\n\n:Redirect to Resident Dashboard (Resident.html);\n:GET /api/residents/{id}/subscriptions;\n:Render Subscribed Wards Grid;\n\nif (Resident Action?) then (Manage Subscriptions)\n  if (Action?) then (Track New Ward)\n    :Click \&quot;Track New Ward\&quot;;\n    :Select Province -&gt; Municipality -&gt; Ward;\n    :POST /api/residents/subscribe;\n  else (Remove Ward)\n    :Click \&quot;Remove Ward\&quot; on Menu;\n    :Confirm via Custom Modal;\n    :DELETE /api/residents/unsubscribe;\n  endif\n  :Update Database &amp; Reload Grid;\n\nelseif (Action?) then (View Ward Ledger)\n  :Click Specific Ward Card;\n  :Redirect to WardPage.html;\n  :Fetch &amp; Render Active Ward Reports;\n  \n  if (Interact with Report?) then (Yes)\n    :Click Report Row;\n    :Open Issue Details Modal;\n    if (Action?) then (Bump Issue)\n      :Click \&quot;Bump this Issue\&quot;;\n      :Increment bump count;\n      :Save ID to localStorage (Prevent re-bump);\n      :Disable Button State;\n    else (Close)\n      :Close Modal;\n    endif\n  else (No)\n  endif\n\nelseif (Action?) then (Submit Report)\n  :Navigate to ReportPage.html;\n  :Pin Location via Leaflet Interactive Map;\n  :Select Province -&gt; Municipality -&gt; Ward (wardSelector.js);\n  :Fill details (Type: Pothole, Streetlight, etc.);\n  :POST /api/reports;\n  :Render Success Confirmation;\n\nelse (Lodge Grievance)\n  :Navigate to Grievance Form;\n  :Identify Municipal Employee (Nullable for Anonymous);\n  :Detail Personnel Complaint;\n  :POST /api/grievances;\n  :Render Success Confirmation;\nendif\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-231">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1438" width="1652" x="10" y="18400" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam conditionStyle inside\n\nstart\n\n:Admin clicks Google Sign-In;\n:UI requests JWT from Google OAuth;\n:POST /api/auth/google {idToken};\n\nif (Is Email \&quot;2820314@students.wits.ac.za\&quot;?) then (Yes)\n  :Return 200 OK &amp; role: &#39;admin&#39;;\n  :Redirect to Admin Dashboard (Admin.html);\n  \n  &#39; Dashboard Initialization\n  :Trigger parallel data fetching;\n  split\n   :GET /api/reports (Filter: Pending);\n   :Render Unassigned Reports;\n  split again\n   :GET /api/workers/pending;\n   :Render Pending Registrations;\n  split again\n   :GET /api/workers/active;\n   :Render Active Duty Roster;\n  end split\n\n  &#39; Admin Actions\n  if (Admin Action?) then (Manage Report)\n    \n    if (Choice?) then (Assign to Worker)\n      :Prompt for EmployeeID;\n      :POST /api/reports/{id}/assign;\n    elseif (Choice?) then (Set Priority)\n      :Select Priority Level;\n      :PUT /api/reports/{id}/priority;\n    else (Delete Report)\n      :Confirm Deletion;\n      :DELETE /api/admin/delete-report/{id};\n    endif\n    \n  elseif (Action?) then (Manage Worker: Approve Pending)\n    :Click \&quot;Approve\&quot;;\n    :PUT /api/workers/validate/{employeeId};\n    \n  else (Manage Worker: Invalidate Active)\n    :Click \&quot;Invalidate\&quot;;\n    :Confirm Account Disablement;\n    :PUT /api/workers/invalidate/{employeeId};\n  endif\n  \n  :Update Database &amp; Refresh Affected UI Panels;\n\nelse (No)\n  :Route to Standard Resident Authentication Flow;\n  stop\nendif\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-232">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="957" width="1577" x="420" y="19860" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nleft to right direction\nskinparam packageStyle rectangle\n\n&#39; Primary Actors (Left Side)\nactor \&quot;Resident\&quot; as Res\nactor \&quot;Central Admin\&quot; as Admin\nactor \&quot;Municipal Employee\&quot; as Worker\n\n&#39; External Services (Right Side)\nactor \&quot;Google OAuth2\\n&lt;&lt;Service&gt;&gt;\&quot; as Google\nactor \&quot;Leaflet Maps API\\n&lt;&lt;Service&gt;&gt;\&quot; as Maps\n\n&#39; System Boundary\nrectangle \&quot;Groundwork Civic Ledger\&quot; {\n  usecase \&quot;Authenticate Session\&quot; as UC_Auth\n  usecase \&quot;Pin Geospatial Location\&quot; as UC_Pin\n  \n  usecase \&quot;Submit Infrastructure Report\&quot; as UC_Report\n  usecase \&quot;Track Ward Ledger\&quot; as UC_Track\n  usecase \&quot;Lodge Personnel Grievance\&quot; as UC_Grievance\n  \n  usecase \&quot;Review &amp; Assign Reports\&quot; as UC_Assign\n  usecase \&quot;Validate Municipal Employees\&quot; as UC_Validate\n  \n  usecase \&quot;Claim Assigned Task\&quot; as UC_Claim\n  usecase \&quot;Resolve Claimed Task\&quot; as UC_Resolve\n}\n\n&#39; Primary Actor Associations\nRes --&gt; UC_Report\nRes --&gt; UC_Track\nRes --&gt; UC_Grievance\n\nAdmin --&gt; UC_Assign\nAdmin --&gt; UC_Validate\n\nWorker --&gt; UC_Claim\nWorker --&gt; UC_Resolve\n\n&#39; Include Relationships (Dotted arrows)\nUC_Report ..&gt; UC_Auth : &lt;&lt;include&gt;&gt;\nUC_Track ..&gt; UC_Auth : &lt;&lt;include&gt;&gt;\nUC_Assign ..&gt; UC_Auth : &lt;&lt;include&gt;&gt;\nUC_Validate ..&gt; UC_Auth : &lt;&lt;include&gt;&gt;\nUC_Claim ..&gt; UC_Auth : &lt;&lt;include&gt;&gt;\nUC_Resolve ..&gt; UC_Auth : &lt;&lt;include&gt;&gt;\n\n&#39; Enforcing the Claim before Resolve rule\nUC_Resolve ..&gt; UC_Claim : &lt;&lt;include&gt;&gt;\n\nUC_Report ..&gt; UC_Pin : &lt;&lt;include&gt;&gt;\n\n&#39; External Service Associations\nUC_Auth -- Google\nUC_Pin -- Maps\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-234">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="588" width="1213" x="-20" y="20840" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam conditionStyle inside\n\nstart\n\n:Municipal Employee clicks Google Sign-In;\n:UI requests JWT from Google OAuth;\n:POST /api/auth/worker/google {idToken};\n\nif (Is Token Valid?) then (Yes)\n  :findOrCreate MunicipalWorker Record;\n  \n  if (Is Employee Blacklisted?) then (Yes)\n    :Return 403 \&quot;Account Blacklisted\&quot;;\n    stop\n  else (No)\n    \n    if (Is Employee Validated by Admin?) then (Yes)\n      :Return 200 OK &amp; employeeId;\n      :Redirect to Employee Dashboard;\n      :GET /api/reports/assigned/{employeeId};\n      \n      if (Has Assigned Tasks?) then (Yes)\n        :Employee views task ledger;\n        \n        if (Task Status?) then (Assigned / Unclaimed)\n          :Click \&quot;Claim Task\&quot;;\n          :PUT /api/reports/{id}/claim;\n          :Update Status to &#39;In Progress&#39;;\n          :Update Database &amp; Reload UI;\n        else (Claimed / In Progress)\n          :Click \&quot;Mark as Complete\&quot;;\n          :PUT /api/reports/{id}/status (Status=&#39;Resolved&#39;);\n          :Update Database &amp; Reload UI;\n        endif\n        \n      else (No)\n        :Display \&quot;No active tasks assigned\&quot;;\n      endif\n      \n    else (No)\n      :Return 403 \&quot;Wait for Admin Approval\&quot;;\n      stop\n    endif\n    \n  endif\n\nelse (No)\n  :Return 401 \&quot;Invalid Security Token\&quot;;\n  stop\nendif\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-235">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="962" width="1532" x="-20" y="21450" as="geometry" />
          </mxCell>
        </UserObject>
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam componentStyle uml2\n\npackage \&quot;Groundwork Web Subsystem (Frontend)\&quot; {\n  [Static Frontend UI] &lt;&lt;component&gt;&gt; as UI\n  [Leaflet.js Map Module] &lt;&lt;component&gt;&gt; as LeafletMap\n}\n\npackage \&quot;Groundwork API Subsystem (Backend)\&quot; {\n  [server.js (Express Middleware)] &lt;&lt;component&gt;&gt; as Server\n  \n  [Worker Router] &lt;&lt;component&gt;&gt; as WorkerRoute\n  [Resident Router] &lt;&lt;component&gt;&gt; as ResidentRoute\n  [Report Router] &lt;&lt;component&gt;&gt; as ReportRoute\n  [Geography Router] &lt;&lt;component&gt;&gt; as GeoRoute\n}\n\npackage \&quot;Data Models Subsystem\&quot; {\n  [Sequelize Index] &lt;&lt;component&gt;&gt; as SeqIndex\n}\n\n&#39; External Services\n[Google OAuth2] &lt;&lt;component&gt;&gt; as GoogleAuth\n[OpenStreetMap Tile Server] &lt;&lt;component&gt;&gt; as OSM\ndatabase \&quot;MySQL\&quot; &lt;&lt;database&gt;&gt; as DB\n\n&#39; Frontend Interfaces (Ball and Socket)\nUI -(0- Server : \&quot; HTTP Requests\&quot;\nUI -(0- LeafletMap : \&quot; Initialize Coordinates\&quot;\nLeafletMap -(0- OSM : \&quot; Fetch Map Tiles (.png)\&quot;\n\n&#39; Backend to External Auth\nServer -0)- GoogleAuth : \&quot; JWT Validation\&quot;\n\n&#39; API Routing (Ball and Socket)\nServer -(0- WorkerRoute : \&quot; /api/workers\&quot;\nServer -(0- ResidentRoute : \&quot; /api/residents\&quot;\nServer -(0- ReportRoute : \&quot; /api/reports\&quot;\nServer -(0- GeoRoute : \&quot; /api/geography\&quot;\n\n&#39; ORM Connections (Ball and Socket)\nWorkerRoute -(0- SeqIndex : \&quot; ORM Queries\&quot;\nResidentRoute -(0- SeqIndex : \&quot; ORM Queries\&quot;\nReportRoute -(0- SeqIndex : \&quot; ORM Queries\&quot;\nGeoRoute -(0- SeqIndex : \&quot; ORM Queries\&quot;\n\n&#39; Database Connection (Ball and Socket)\nSeqIndex -(0- DB : \&quot; TCP Connection\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="f1CdBVBtIYrvmNaZUmw5-237">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="754" width="1149" x="-20" y="22460" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
